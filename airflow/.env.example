# Airflow webserver secret key
# Use any long random string for local development.
AIRFLOW__WEBSERVER__SECRET_KEY=change-me-to-a-long-random-string

# Target Postgres connection used by PostgresHook(conn_id="osm_postgres")
# Format:
# postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
AIRFLOW_CONN_OSM_POSTGRES=postgresql://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require

# =====================================================
# OSM pipeline runtime controls
# =====================================================

# Execution strategy
# Allowed values: pure_parallel | batch
OSM_STRATEGY=batch

# Maximum number of parallel mapped table tasks per DAG run
# Used when OSM_STRATEGY=pure_parallel
OSM_MAX_ACTIVE_TIS_PER_DAGRUN=10

# Batch execution controls
# Used when OSM_STRATEGY=batch
OSM_BATCH_SIZE=2
OSM_MAX_ACTIVE_BATCHES=10

# Retry behavior for table-processing tasks
OSM_TASK_RETRIES=3
OSM_RETRY_DELAY_MINUTES=2