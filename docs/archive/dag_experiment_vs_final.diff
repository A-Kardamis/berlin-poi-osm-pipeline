+    @task
+    def flatten_results(maybe_nested: list) -> list[dict]:
+        """
+        Flatten results from batch strategy:
+        - pure_parallel returns list[dict]
+        - batch returns list[list[dict]]
+        """
+        if not maybe_nested:
+            return []
+        # If first element is a list, we assume list[list[dict]]
+        if isinstance(maybe_nested[0], list):
+            flat: list[dict] = []
+            for chunk in maybe_nested:
+                flat.extend(chunk)
+            return flat
+        # Otherwise list[dict]
+        return maybe_nested  # type: ignore[return-value]
+
+    @task
+    def summarize_run(
+        experiment_run_id: str,
