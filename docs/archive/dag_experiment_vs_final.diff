+def ensure_experiment_tables(cur):
+    """Tables for execution strategy experiment summaries."""
+    cur.execute(
+        f"""
+        CREATE TABLE IF NOT EXISTS {TARGET_SCHEMA}.osm_experiment_results (
+            run_id TEXT PRIMARY KEY,
+            run_ts TIMESTAMPTZ NOT NULL,
+            dag_id TEXT NOT NULL,
+            strategy TEXT NOT NULL,
+            run_label TEXT NULL,
+            concurrency_limit INTEGER NULL,
+            batch_size INTEGER NULL,
+            tables_total INTEGER NOT NULL,
+            tables_succeeded INTEGER NOT NULL,
+            tables_failed INTEGER NOT NULL,
+            tables_retried INTEGER NOT NULL,
+            dag_duration_sec DOUBLE PRECISION NOT NULL,
+            avg_table_duration_sec DOUBLE PRECISION NOT NULL,
+            p95_table_duration_sec DOUBLE PRECISION NULL,
+            max_table_duration_sec DOUBLE PRECISION NOT NULL,
+            max_db_connections_observed INTEGER NULL,
+            notes TEXT NULL,
+            created_at TIMESTAMPTZ NOT NULL DEFAULT now()
+        );
+        """
+    )
+
+    cur.execute(
+        f"""
+        CREATE TABLE IF NOT EXISTS {TARGET_SCHEMA}.osm_experiment_results_table (
+            run_id TEXT NOT NULL,
+            table_name TEXT NOT NULL,
+            status TEXT NOT NULL,
+            duration_sec DOUBLE PRECISION NOT NULL,
+            attempts INTEGER NOT NULL,
+            db_connections_observed INTEGER NULL,
+            records_fetched INTEGER NULL,
+            records_inserted INTEGER NULL,
+            error TEXT NULL,
+            PRIMARY KEY (run_id, table_name),
+            FOREIGN KEY (run_id) REFERENCES {TARGET_SCHEMA}.osm_experiment_results(run_id)
+        );
+        """
+    )
+
+    cur.execute(
+        f"ALTER TABLE {TARGET_SCHEMA}.osm_experiment_results ADD COLUMN IF NOT EXISTS run_label TEXT NULL;"
+    )
+    cur.execute(
+        f"ALTER TABLE {TARGET_SCHEMA}.osm_experiment_results ADD COLUMN IF NOT EXISTS max_db_connections_observed INTEGER NULL;"
+    )
+    cur.execute(
+        f"ALTER TABLE {TARGET_SCHEMA}.osm_experiment_results_table ADD COLUMN IF NOT EXISTS db_connections_observed INTEGER NULL;"
+    )
+
